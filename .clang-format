---
# ==============================================================================
# SiLog 项目 clang-format 配置文件
# ==============================================================================

# 基础设置
Language: Cpp                    # C/C++ 代码
BasedOnStyle: LLVM               # 基于 LLVM 风格
IndentWidth: 4                   # 缩进宽度为 4 个空格
UseTab: Never                    # 使用空格而非 Tab
ColumnLimit: 120                 # 每行最大 120 字符

# ==============================================================================
# 大括号换行风格
# ==============================================================================
BreakBeforeBraces: Custom        # 使用自定义大括号风格
BraceWrapping:
  AfterFunction: true            # 函数左大括号换行
  AfterControlStatement: false   # 控制语句(if/while/for)左大括号不换行
  AfterNamespace: false          # namespace 左大括号不换行
  AfterClass: false              # class 左大括号不换行
  AfterStruct: false             # struct 左大括号不换行
  AfterUnion: false              # union 左大括号不换行
  AfterExternBlock: false        # extern 块左大括号不换行
  BeforeCatch: false             # catch 前不换行
  BeforeElse: false              # else 前不换行
  SplitEmptyFunction: false      # 空函数不拆分
  SplitEmptyRecord: false        # 空结构体/类不拆分
  SplitEmptyNamespace: false     # 空 namespace 不拆分

# ==============================================================================
# 函数和表达式风格
# ==============================================================================
AllowShortFunctionsOnASingleLine: Inline  # 只允许内联函数单行
AllowShortEnumsOnASingleLine: false       # 枚举不强制单行
AlignAfterOpenBracket: Align              # 括号内参数对齐左括号
ContinuationIndentWidth: 4                # 续行缩进宽度

# ==============================================================================
# 操作符和表达式换行
# ==============================================================================
BreakBeforeBinaryOperators: None          # 二元操作符前不强制换行
BreakBeforeTernaryOperators: false        # 三元操作符前不换行
AlwaysBreakAfterReturnType: None          # 返回类型后不强制换行
AlwaysBreakBeforeMultilineStrings: false  # 多行字符串前不强制换行
BreakConstructorInitializers: BeforeComma # 构造函数初始化列表在逗号前换行

# ==============================================================================
# 对齐和排序
# ==============================================================================
AlignConsecutiveMacros: true      # 对齐连续的宏定义（反斜杠对齐）
AlignEscapedNewlines: Left        # 宏定义换行时反斜杠左对齐
PointerAlignment: Right           # 指针星号靠右 (int *a)
SortIncludes: true                # 排序 #include 语句

# ==============================================================================
# 注释说明
# ==============================================================================
# 此配置遵循项目代码规范：
# - 函数定义的大括号换行
# - 控制语句的大括号不换行
# - 使用 4 空格缩进
# - 指针类型写作 int *a 而非 int* a
# ==============================================================================
